{
  "version": 3,
  "kvStoreName": "job-pipeline-v3",
  "datasetPrefix": "jobsearch-v3",
  "run": {
    "maxItemsPerSource": 1200,
    "maxTotalItems": 10000,
    "stopOnCollectorErrors": false
  },
  "sources": [
    {
      "id": "fantastic_nationwide",
      "type": "apify_actor",
      "enabled": true,
      "actorId": "fantastic-jobs/career-site-job-listing-feed",
      "adapter": "fantastic_feed",
      "input": {
        "limit": 1000,
        "titleSearch": ["Unity", "Game Developer", "Game Programmer", "Game Designer"],
        "locationSearch": ["United States"],
        "aiWorkArrangementFilter": ["Remote OK", "Remote Solely", "Hybrid", "On-site"],
        "descriptionType": "text",
        "includeAi": true,
        "includeLinkedIn": true,
        "includeJobAggregator": true,
        "makeRecordsUnique": true
      }
    },
    {
      "id": "fantastic_ma",
      "type": "apify_actor",
      "enabled": true,
      "actorId": "fantastic-jobs/career-site-job-listing-feed",
      "adapter": "fantastic_feed",
      "input": {
        "limit": 1000,
        "titleSearch": [
          "Implementation Specialist", "Implementation Consultant", "Onboarding Specialist",
          "Customer Success", "Technical Account",
          "Sales Engineer",
          "Client Success",
          "Technical Support Engineer", "Support Engineer", "Product Support Engineer", "Application Support",
          "Solutions Engineer", "Solutions Consultant", "Technical Solutions"
        ],
        "locationSearch": ["Massachusetts"],
        "aiWorkArrangementFilter": ["Remote OK", "Remote Solely", "Hybrid", "On-site"],
        "descriptionType": "text",
        "includeAi": true,
        "includeLinkedIn": true,
        "includeJobAggregator": true,
        "makeRecordsUnique": true
      }
    },
    {
      "id": "linkedin_nationwide",
      "type": "apify_actor",
      "enabled": true,
      "actorId": "fantastic-jobs/advanced-linkedin-job-search-api",
      "adapter": "linkedin_generic",
      "input": {
        "timeRange": "6m",
        "limit": 1000,
        "titleSearch": ["Unity", "Game Developer", "Game Programmer", "Game Designer"],
        "locationSearch": ["United States"],
        "descriptionType": "text"
      }
    },
    {
      "id": "linkedin_ma",
      "type": "apify_actor",
      "enabled": true,
      "actorId": "fantastic-jobs/advanced-linkedin-job-search-api",
      "adapter": "linkedin_generic",
      "input": {
        "timeRange": "6m",
        "limit": 1000,
        "titleSearch": [
          "Implementation Specialist", "Implementation Consultant", "Onboarding Specialist",
          "Customer Success", "Technical Account",
          "Sales Engineer",
          "Client Success",
          "Technical Support Engineer", "Support Engineer", "Product Support Engineer", "Application Support",
          "Solutions Engineer", "Solutions Consultant", "Technical Solutions"
        ],
        "locationSearch": ["Massachusetts"],
        "descriptionType": "text"
      }
    },
    {
      "id": "remoteok",
      "type": "remoteok",
      "enabled": false
    },
    {
      "id": "gracklehq",
      "type": "gracklehq",
      "enabled": true,
      "country": "USA",
      "departments": ["Engineering", "Design"],
      "maxPages": 25
    },
    {
      "id": "builtin_unity",
      "type": "builtin",
      "enabled": true,
      "query": "unity developer",
      "allLocations": true,
      "maxPages": 100
    },
    {
      "id": "builtin_game_dev",
      "type": "builtin",
      "enabled": true,
      "query": "game developer",
      "allLocations": true,
      "maxPages": 100
    },
    {
      "id": "builtin_game_designer",
      "type": "builtin",
      "enabled": true,
      "query": "game designer",
      "allLocations": true,
      "maxPages": 100
    },
    {
      "id": "builtin_level_designer",
      "type": "builtin",
      "enabled": true,
      "query": "level designer",
      "allLocations": true,
      "maxPages": 100
    },
    {
      "id": "builtin_gameplay_engineer",
      "type": "builtin",
      "enabled": true,
      "query": "gameplay engineer",
      "allLocations": true,
      "maxPages": 100
    },
    {
      "id": "usajobs_gamedev",
      "type": "usajobs",
      "enabled": true,
      "requiredEnv": ["USAJOBS_API_KEY", "USAJOBS_EMAIL"],
      "keyword": "unity simulation game development",
      "whoMayApply": "public",
      "datePosted": 30
    },
    {
      "id": "usajobs_ma_tech",
      "type": "usajobs",
      "enabled": true,
      "requiredEnv": ["USAJOBS_API_KEY", "USAJOBS_EMAIL"],
      "keyword": "software developer",
      "locationName": "Massachusetts",
      "whoMayApply": "public",
      "datePosted": 30
    }
  ],
  "merge": {
    "preferLinkedInApply": true
  },
  "scoring": {
    "enabled": true,
    "model": "gpt-4.1-mini",
    "threshold": 70,
    "gateOnLocation": false,
    "concurrency": 8,
    "maxDescriptionChars": 12000,
    "rubricUrl": "http://forgaard.com/jobsearch/rubric.md"
  },
  "notify": {
    "enabled": true,
    "toEmail": "randy@forgaard.com",
    "subjectPrefix": "[Kyle Job Search]",
    "sendEvenIfEmpty": true
  },
  "diagnostics": {
    "enabled": true,
    "mode": "gist",
    "gistIdEnv": "GIST_ID",
    "githubTokenEnv": "GITHUB_TOKEN",
    "gistFilenameEnv": "GIST_FILENAME",
    "pagesViewerUrl": "https://hauntguy.github.io/kyle-job-search-apify/job_search_log.html",
    "gistRawUrlTemplate": "https://gist.githubusercontent.com/HauntGuy/<GIST_ID>/raw/job_search_log.html"
  }
}
